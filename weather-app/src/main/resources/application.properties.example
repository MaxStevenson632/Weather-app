spring.application.name=weather-app

# OpenWeather API key
weather.api.key=YOUR_API_KEY_HERE

# Base URLs for different endpoints
weather.api.current-url=https://api.openweathermap.org/data/2.5/weather
weather.api.forecast-url=https://api.openweathermap.org/data/2.5/forecast
weather.api.geo-url=http://api.openweathermap.org/geo/1.0/direct